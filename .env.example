# ── Required ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Optional ──────────────────────────────────────────────────────────────

# Resy API key (a public one is used by default, but you can grab your own
# from the browser devtools network tab when logged into resy.com)
# RESY_API_KEY=ResyAPI api_key="VbWk7s3L4KiK5fzlO7JD3Q5EYolJI7n5"

# How often to check availability (seconds). Default: 300 (5 min)
# CHECK_INTERVAL_SECONDS=300

# SQLite database file path. Default: resywatch.db
# DB_PATH=resywatch.db
